# Piantare — production env contract.
#
# These variables must be set in the deployment platform (Vercel project
# environment variables), NOT committed. This file documents what is required.
#
# Schema validated in src/config/env.ts (zod, fail-fast on boot).
# Same shape as .env.local.example — the platform is the difference, not the schema.

# --- Supabase (required, public) ---
# The production project URL + anon key. PUBLIC: shipped to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase service-role (required for admin paths, server-only) ---
# Used by services/supabase/admin.ts for:
#   - createOrganization (org + membership insert)
#   - createProduct (lab-side membership verification + insert)
#   - createOrder, transitionOrderStatus (cross-side membership checks + writes)
#   - generateInvoiceForOrder, markInvoicePaid
#
# In Vercel: mark this variable as "Sensitive". DO NOT expose to the edge.
# Our middleware runtime is pinned to "nodejs" (middleware.ts line 41), so the
# admin client never instantiates at the edge.
SUPABASE_SERVICE_ROLE_KEY=
