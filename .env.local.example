# Piantare — local development env contract.
# Copy to `.env.local` and fill values. `.env.local` is gitignored.
# Schema validated in src/config/env.ts (zod, fail-fast on boot).

# --- Supabase (required) ---
# Project: Piantare (id: ydmcyituvsjnfagxjgka, region: us-east-2)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase service-role (OPTIONAL, server-only, NEVER ship to browser) ---
# Required only for admin paths / scripts / jobs that bypass RLS.
# If absent, services/supabase/admin.ts throws on use.
# DO NOT add to a deployed edge runtime.
SUPABASE_SERVICE_ROLE_KEY=
